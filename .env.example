# RabbitMQ Configuration (Candystore)
# Set RABBITMQ_PASS in your environment or .env.local
RABBIT_URL=amqp://delorenj:${RABBITMQ_PASS}@192.168.1.12:5672/
EXCHANGE_NAME=bloodbank.events.v1
QUEUE_NAME=candystore.storage

# Database Configuration
# Set DATABASE_PASSWORD in your environment
#DATABASE_URL=sqlite+aiosqlite:///./candystore.db
DATABASE_URL=postgresql+asyncpg://delorenj:${DATABASE_PASSWORD}@192.168.1.12:5432/candystore

# API Configuration
API_HOST=0.0.0.0
API_PORT=8683

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json # or 'console'

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
